PORT=3000
HOST=0.0.0.0
# Şifre yoksa: mysql://root@localhost:3306/lingola_daily_words
# Şifre varsa:  mysql://root:SIFRE@localhost:3306/lingola_daily_words
DATABASE_URL="mysql://root@localhost:3306/lingola_daily_words"

# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Optional: paste JSON inline instead of file path
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Admin import endpoints (required for /api/admin/*)
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Optional comma-separated IP allowlist for admin routes
# ADMIN_IP_ALLOWLIST=127.0.0.1,::1
