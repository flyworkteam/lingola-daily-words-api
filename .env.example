PORT=3000
# API dinleme adresi — asla MySQL sunucu IP'si yazmayın
HOST=0.0.0.0

# Flutter / mobil uygulamanın kullanacağı kök URL (üretim)
PUBLIC_API_BASE_URL=http://5.39.8.160:3000

# --- Veritabanı (üretim / müşteri sunucusu) ---
# Sunucuda API ile aynı makine: host 127.0.0.1 (5.39.8.160 DEĞİL)
# DATABASE_URL="mysql://lingoladailywordsUser:SIFRE@127.0.0.1:3306/lingoladailywords"
#
# Mac'te npm run dev için .env.local kullanın (cp .env.local.example .env.local):
# DATABASE_URL="mysql://root@127.0.0.1:3306/lingoladailywords_local"

DATABASE_URL="mysql://lingoladailywordsUser:SIFRE@127.0.0.1:3306/lingoladailywords"

# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Optional: paste JSON inline instead of file path
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Harici kelime import API (opsiyonel, /api/admin/import-words)
VERB_API_BASE_URL=http://verbs.fly-work.com/api
VERB_API_TOKEN=your-token

# Admin import endpoints (required for /api/admin/*)
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Optional comma-separated IP allowlist for admin routes
# ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# Bunny CDN (pull zone)
CDN_HOSTNAME=lingoladailywords.b-cdn.net
CDN_USERNAME=lingoladailywords
CDN_PASSWORD=your-bunny-storage-password
