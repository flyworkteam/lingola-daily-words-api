# Yerel geliştirme — kopyalayın: cp .env.local.example .env.local
# .env.local, .env üzerine yazar (uzak MySQL'i devre dışı bırakır).

HOST=0.0.0.0
PORT=3000

# Üretim Flutter URL'sini yerelde kullanmayın; boş bırakın veya Mac IP'niz
# PUBLIC_API_BASE_URL=

DATABASE_URL="mysql://root@127.0.0.1:3306/lingoladailywords_local"

FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
ADMIN_API_KEY=local-dev-admin-key

VERB_API_BASE_URL=http://verbs.fly-work.com/api
VERB_API_TOKEN=your-token
